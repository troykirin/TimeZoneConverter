# Environment Configuration Example
# Copy this file to .env and update with your values

# Application
APP_NAME=TimeZoneConverter
APP_PORT=3000
APP_ENV=development

# MCP Configuration
MCP_ENABLED=true
MCP_SERVER_URL=http://localhost:8080
MCP_API_KEY=your_mcp_api_key_here

# Feature Flags
ENABLE_PWA=true
ENABLE_ANALYTICS=false
